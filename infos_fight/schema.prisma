generator client {
  provider        = "prisma-client-js"
  output          = "../../prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  binaryTargets   = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Concentration {
  id    Int     @id(map: "PK_8e5d1783d48bab689b191b0d2af") @default(autoincrement())
  dinoz Dinoz[]

  @@map("concentration")
}

model Dinoz {
  id                 Int                    @id(map: "PK_297ca7f55b56853c204d8301fb6") @default(autoincrement())
  leaderId           Int?                   @map("following")
  name               String                 @db.VarChar
  raceId             Int
  level              Int
  nextUpElementId    Int
  nextUpAltElementId Int
  placeId            Int
  canChangeName      Boolean
  display            String                 @db.VarChar
  life               Int
  maxLife            Int
  experience         Int
  nbrUpFire          Int
  nbrUpWood          Int
  nbrUpWater         Int
  nbrUpLightning     Int
  nbrUpAir           Int
  createdDate        DateTime               @default(now()) @db.Timestamp(6)
  updatedDate        DateTime               @default(now()) @updatedAt @db.Timestamp(6)
  order              Int?
  concentrationId    Int?
  fight              Boolean                @default(true)
  gather             Boolean                @default(true)
  remaining          Int                    @default(2)
  FBTournamentStep   Int                    @default(0)
  unavailableReason  UnavailableReason?
  seed               String                 @default(dbgenerated("uuid_generate_v4()"))
  playerId           String                 @db.Uuid
  buildId            String?                @db.Uuid
  build              DinozBuild?            @relation(fields: [buildId], references: [id], onDelete: SetNull)
  catches            DinozCatch[]
  logs               Log[]
  Moderation         Moderation[]
  offers             Offer[]
  Pantheon           Pantheon[]
  player             Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_064135f23ecaf0207af9926d7c9")
  concentration      Concentration?         @relation(fields: [concentrationId], references: [id], onUpdate: NoAction, map: "FK_693d1e839cbd13471ff3721b994")
  leader             Dinoz?                 @relation("DinozFollowers", fields: [leaderId], references: [id])
  followers          Dinoz[]                @relation("DinozFollowers")
  items              DinozItem[]
  dinozItemsToDinoz  DinozItemToDinoz[]
  missions           DinozMission[]
  skills             DinozSkill[]
  unlockableSkills   DinozSkillUnlockable[]
  status             DinozStatus[]
  npcs               NPC[]
  DojoOpponents      DojoOpponents[]
  DojoTeam           DojoTeam[]
  TournamentTeam     TournamentTeam[]

  @@index([playerId], map: "idx_playerId")
  @@index([buildId])
  @@map("dinoz")
}

model DinozItem {
  id               Int                @id(map: "PK_c02e01190111511642a4c3538f0") @default(autoincrement())
  itemId           Int
  dinozId          Int?
  dinoz            Dinoz?             @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_37055da55534196f2248a1b5c6d")
  dinozItemToDinoz DinozItemToDinoz[]
  GameDinoz        GameDinoz?         @relation(fields: [gameDinozId], references: [id], onDelete: Cascade)
  gameDinozId      Int?

  @@index([dinozId])
  @@map("dinoz_item")
}

model DinozItemToDinoz {
  dinozId     Int
  dinozItemId Int
  dinoz       Dinoz      @relation(fields: [dinozId], references: [id], onDelete: Cascade, map: "FK_4e81bd56b675264ba5f30a5f109")
  dinoz_item  DinozItem  @relation(fields: [dinozItemId], references: [id], onDelete: Cascade, map: "FK_e90f6271f11b3522312139ef3a9")
  GameDinoz   GameDinoz? @relation(fields: [gameDinozId], references: [id], onDelete: Cascade)
  gameDinozId Int?

  @@id([dinozId, dinozItemId], map: "PK_e7161ad9702ca574280cf1a1617")
  @@index([dinozId], map: "IDX_4e81bd56b675264ba5f30a5f10")
  @@index([dinozItemId], map: "IDX_e90f6271f11b3522312139ef3a")
  @@map("dinoz_items_dinoz_item")
}

model DinozMission {
  id         Int      @id(map: "PK_dfeb1245e68d72db9a6c9402ab7") @default(autoincrement())
  missionId  Int
  dinozId    Int?
  step       Int
  isFinished Boolean?
  progress   Int?
  dinoz      Dinoz?   @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_f408ddb692ab5519808f24fb2b7")

  @@unique([missionId, dinozId])
  @@index([dinozId])
  @@map("dinoz_mission")
}

model DinozSkill {
  id          Int        @id(map: "PK_c4109fad8627da673d3614fbc01") @default(autoincrement())
  skillId     Int
  state       Boolean    @default(true)
  dinozId     Int?
  dinoz       Dinoz?     @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_5662d0ad643e55696f10bcbc858")
  GameDinoz   GameDinoz? @relation(fields: [gameDinozId], references: [id], onDelete: Cascade)
  gameDinozId Int?

  @@unique([skillId, dinozId])
  @@index([dinozId])
  @@map("dinoz_skill")
}

model DinozSkillUnlockable {
  id          Int        @id(map: "PK_f61132504207a4379a96a324e93") @default(autoincrement())
  skillId     Int
  dinozId     Int?
  dinoz       Dinoz?     @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_db6b95479693f3e4b5948800cf8")
  GameDinoz   GameDinoz? @relation(fields: [gameDinozId], references: [id], onDelete: Cascade)
  gameDinozId Int?

  @@map("dinoz_skill_unlockable")
}

model DinozStatus {
  id          Int        @id(map: "PK_149653f1934603aede93803c9de") @default(autoincrement())
  statusId    Int
  dinozId     Int?
  dinoz       Dinoz?     @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_ec5230fd4ad653770e13558df7d")
  gameDinozId Int?
  gameDinoz   GameDinoz? @relation(fields: [gameDinozId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([statusId, dinozId])
  @@index([dinozId])
  @@map("dinoz_status")
}

model DinozBuild {
  id        String  @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  playerId  String  @db.Uuid
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  skills    Int[]   @default([])
  shareable Boolean @default(false)
  name      String  @db.VarChar
  dinozs    Dinoz[]

  @@index([playerId, shareable])
}

model migrations {
  id        Int    @id(map: "PK_8c82d7f526340ab734260ea46be") @default(autoincrement())
  timestamp BigInt
  name      String @db.VarChar
}

model News {
  id           Int        @id(map: "PK_39a43dfcb6007180f04aff2357e") @default(autoincrement())
  title        String?    @db.VarChar
  type         NewsType   @default(update)
  image        Bytes?
  frenchTitle  String?    @db.VarChar
  frenchText   String?    @db.VarChar
  englishTitle String?    @db.VarChar
  englishText  String?    @db.VarChar
  spanishTitle String?    @db.VarChar
  spanishText  String?    @db.VarChar
  germanTitle  String?    @db.VarChar
  germanText   String?    @db.VarChar
  createdDate  DateTime   @default(now()) @db.Timestamp(6)
  updatedDate  DateTime   @default(now()) @updatedAt @db.Timestamp(6)
  poll         Poll?
  likedBy      NewsLike[]

  @@map("news")
}

model Poll {
  id          Int          @id @default(autoincrement())
  newsId      Int          @unique
  isActive    Boolean      @default(true)
  createdDate DateTime     @default(now()) @db.Timestamp(6)
  endDate     DateTime     @db.Timestamp(6)
  news        News         @relation(fields: [newsId], references: [id], onDelete: Cascade)
  options     PollOption[]
  votes       PollVote[]

  @@map("polls")
}

model PollOption {
  id          Int        @id @default(autoincrement())
  pollId      Int
  optionText  String     @db.VarChar
  orderIndex  Int        @default(0)
  createdDate DateTime   @default(now()) @db.Timestamp(6)
  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes       PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id           Int        @id @default(autoincrement())
  pollId       Int
  pollOptionId Int
  playerId     String     @db.Uuid
  votedAt      DateTime   @default(now()) @db.Timestamp(6)
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOption   PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([pollId, playerId], name: "unique_player_vote_per_poll")
  @@index([pollId])
  @@index([playerId])
  @@index([pollId, playerId])
  @@map("poll_votes")
}

model NewsLike {
  newsId    Int
  playerId  String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamp(6)

  news News @relation(fields: [newsId], references: [id])

  @@id([newsId, playerId])
  @@index([newsId])
}

model NPC {
  id      Int    @id(map: "PK_f88acee050bfea2111b399ab49b") @default(autoincrement())
  npcId   Int
  step    String @db.VarChar
  dinozId Int?
  dinoz   Dinoz? @relation(fields: [dinozId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_90ce8a070feaea28d5a39295762")

  @@unique([npcId, dinozId])
  @@index([dinozId])
  @@map("npc")
}

model Player {
  customText           String?
  name                 String             @db.VarChar
  connexionToken       String             @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  money                Int
  quetzuBought         Int
  leader               Boolean            @default(false)
  engineer             Boolean            @default(false)
  cooker               Boolean            @default(false)
  shopKeeper           Boolean            @default(false)
  merchant             Boolean            @default(false)
  priest               Boolean            @default(false)
  teacher              Boolean            @default(false)
  createdDate          DateTime           @default(now()) @db.Timestamp(6)
  updatedDate          DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  lastLogin            DateTime           @default(now()) @db.Timestamp(6)
  clanMemberId         Int?               @unique
  matelasseur          Boolean            @default(false)
  messie               Boolean            @default(false)
  labruteDone          Boolean            @default(false)
  role                 AdminRole          @default(PLAYER)
  lang                 Lang               @default(fr)
  dailyGridRewards     Int                @default(0)
  skipFight            Boolean            @default(false)
  skipLevel            Boolean            @default(false)
  banCaseId            Int?               @unique
  discoveredSkills     Int[]              @default([])
  lastVersionSeen      String             @default("0.16.3")
  id                   String             @id(map: "PK_65edadc946a7faf4b638d5e8885") @unique(map: "player_id_idx") @db.Uuid
  leaderOf             Clan?              @relation("leader")
  ClanHistory          ClanHistory[]
  ClanJoinRequest      ClanJoinRequest?   @relation("clanRequest")
  ClanMember           ClanMember?
  createdConversations Conversation[]     @relation("CreatedConversations")
  Conversation         Conversation[]
  logs                 Log[]
  messages             Message[]
  reportedCases        Moderation[]       @relation("ReporterRelation")
  targetedCases        Moderation[]       @relation("TargetRelation")
  notifications        Notification[]
  offers               Offer[]
  bids                 OfferBid[]
  Pantheon             Pantheon[]
  conversations        Participants[]
  usernameHistory      UsernameHistory[]
  ClanMessage          ClanMessage[]
  dinoz                Dinoz[]
  banCase              Moderation?        @relation("AcceptedBan", fields: [banCaseId], references: [id])
  playerTracking       PlayerTracking[]
  dinozShop            PlayerDinozShop[]
  gathers              PlayerGather[]
  ingredients          PlayerIngredient[]
  items                PlayerItem[]
  quests               PlayerQuest[]
  rewards              PlayerReward[]
  ranking              Ranking?
  Dojo                 Dojo?
  FightArchive         FightArchive[]     @relation("PlayerRelation")
  LeftFightArchives    FightArchive[]     @relation("LeftPlayerRelation")
  RightFightArchives   FightArchive[]     @relation("RightPlayerRelation")
  FightWatched         FightWatched[]
  GameDinoz            GameDinoz[]
  ips                  PlayerIp[]
  pollVotes            PollVote[]
  Events               Events[]
  dinozBuilds          DinozBuild[]

  @@map("player")
}

model PlayerIp {
  id       Int    @id @default(autoincrement())
  ip       String @db.Inet
  playerId String @db.Uuid
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, ip])
  @@index([ip])
}

model Dojo {
  id                   String                 @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  playerId             String                 @unique() @db.Uuid
  player               Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team                 DojoTeam[]
  activeChallenge      Json                   @db.JsonB
  DojoChallengeHistory DojoChallengeHistory[]
  reputation           Int                    @default(0)
  DojoOpponents        DojoOpponents[]
  teamUpdate           DateTime?
  dailyReset           Int                    @default(0)
  TournamentTeam       TournamentTeam?        @relation(fields: [tournamentTeamId], references: [id])
  tournamentTeamId     String?                @unique @db.Uuid

  @@index([playerId])
  @@map("dojo")
}

model DojoTeam {
  id      String  @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dojoId  String  @db.Uuid
  dojo    Dojo    @relation(fields: [dojoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dinozId Int
  dinoz   Dinoz   @relation(fields: [dinozId], onDelete: Cascade, references: [id])
  fighted Boolean @default(false)

  @@unique([dojoId, dinozId])
  @@index([dojoId])
}

model DojoOpponents {
  id       String  @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dojoId   String  @db.Uuid
  dojo     Dojo    @relation(fields: [dojoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dinozId  Int
  dinoz    Dinoz   @relation(fields: [dinozId], onDelete: Cascade, references: [id])
  fighted  Boolean @default(false)
  achieved Boolean @default(false)

  @@unique([dojoId, dinozId])
  @@index([dojoId])
}

model DojoChallengeHistory {
  id         String   @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dojoId     String   @db.Uuid
  dojo       Dojo     @relation(fields: [dojoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  myDinozId  Int
  opponentId Int
  challenge  String
  victory    Boolean
  achieved   Boolean
  archivedAt DateTime @default(now()) @db.Date

  @@index([dojoId])
}

model UsernameHistory {
  id       Int     @id @default(autoincrement())
  username String  @db.VarChar
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([playerId])
}

model PlayerDinozShop {
  id       Int     @id(map: "PK_046dc73096360ffb3c1cca7fe72") @default(autoincrement())
  raceId   Int
  display  String  @db.VarChar
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_c79ab61aa32fe6e81c03a7d87d1")

  @@map("player_dinoz_shop")
}

model PlayerGather {
  id       Int     @id(map: "PK_aafad0867df96551953200209c7") @default(autoincrement())
  place    Int
  type     Int
  grid     Int[]
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_86eed52f66f7126e4dc7a998cdf")

  @@index([playerId])
  @@map("player_gather")
}

model PlayerIngredient {
  id           Int     @id(map: "PK_3ae5ca9730144d7456c16386869") @default(autoincrement())
  ingredientId Int
  quantity     Int
  playerId     String? @db.Uuid
  player       Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_ad198392886a52e7f184474a0d6")

  @@unique([ingredientId, playerId])
  @@index([playerId])
  @@map("player_ingredient")
}

model PlayerItem {
  id       Int     @id(map: "PK_47496d16c61f1b09af5c2399993") @default(autoincrement())
  itemId   Int
  quantity Int
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_21535fcb93f8613fd893b74b08b")

  @@unique([itemId, playerId])
  @@index([playerId])
  @@map("player_item")
}

model PlayerQuest {
  id          Int     @id(map: "PK_8cb4cc9b423807c511f24c0faa3") @default(autoincrement())
  questId     Int
  progression Int
  tracking    Int     @default(0)
  playerId    String? @db.Uuid
  player      Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_1b5b041fab3362c845c142ca3b0")

  @@unique([questId, playerId])
  @@map("player_quest")
}

model PlayerReward {
  id       Int     @id(map: "PK_6602753ecef4920f197de910599") @default(autoincrement())
  rewardId Int
  playerId String? @db.Uuid
  player   Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_9cf142b3a6fa3e0faec7f8debfb")

  @@unique([rewardId, playerId])
  @@map("player_reward")
}

model Ranking {
  id         Int     @id(map: "PK_bf82b8f271e50232e6a3fcb09a9") @default(autoincrement())
  dinozCount Int     @default(0)
  points     Int     @default(0)
  average    Int     @default(0)
  completion Int     @default(0)
  dojo       Int     @default(0)
  playerId   String? @unique(map: "REL_3ac96196d0a3851989be8c52a9") @db.Uuid
  player     Player? @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "FK_3ac96196d0a3851989be8c52a9a")

  @@index([playerId])
  @@map("ranking")
}

model Secret {
  key   String @id @db.VarChar
  value String @db.VarChar

  @@map("secret")
}

model OfferItem {
  id           Int     @id @default(autoincrement())
  offerId      Int
  itemId       Int
  quantity     Int
  isIngredient Boolean
  offer        Offer   @relation(fields: [offerId], onDelete: Cascade, references: [id])
}

model OfferBid {
  id       Int     @id @default(autoincrement())
  offerId  Int
  value    Int
  userId   String? @db.Uuid
  userName String
  offer    Offer   @relation(fields: [offerId], references: [id])
  user     Player? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Offer {
  id           Int         @id @default(autoincrement())
  endDate      DateTime
  dinozId      Int?
  total        Int
  status       OfferStatus @default(ONGOING)
  dinozDetails String?
  sellerId     String?     @db.Uuid
  sellerName   String
  dinoz        Dinoz?      @relation(fields: [dinozId], references: [id])
  seller       Player?     @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  bids         OfferBid[]
  items        OfferItem[]
}

model Log {
  id          Int      @id @default(autoincrement())
  dinozId     Int?
  type        LogType
  values      String[] @default([])
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  playerId    String?  @db.Uuid
  playerOldId String
  dinoz       Dinoz?   @relation(fields: [dinozId], references: [id])
  player      Player?  @relation(fields: [playerId], references: [id])

  @@index([playerId, dinozId, type])
}

model DinozCatch {
  id        Int    @id @default(autoincrement())
  dinozId   Int
  hp        Int
  monsterId String
  dinoz     Dinoz  @relation(fields: [dinozId], references: [id], onDelete: Cascade)
}

model PlayerTracking {
  id       Int    @id @default(autoincrement())
  stat     String
  quantity Int
  playerId String @db.Uuid
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([stat, playerId])
  @@index([playerId])
  @@map("playerTracking")
}

model Pantheon {
  id         Int           @id @default(autoincrement())
  motif      PantheonMotif
  dinozId    Int?
  date       DateTime      @default(now()) @db.Timestamp(6)
  indicator  Int?
  playerId   String?       @db.Uuid
  playerName String
  image      Bytes?
  dinoz      Dinoz?        @relation(fields: [dinozId], references: [id])
  player     Player?       @relation(fields: [playerId], references: [id])
}

model Clan {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  treasureValue Int               @default(0)
  creationDate  DateTime          @default(now()) @db.Timestamp(6)
  clanWarId     Int?
  banner        Bytes?
  leaderId      String            @unique @db.Uuid
  langs         Lang[]            @default([fr])
  war           ClanWar?          @relation(fields: [clanWarId], references: [id])
  leader        Player            @relation("leader", fields: [leaderId], references: [id])
  history       ClanHistory[]
  joinRequests  ClanJoinRequest[]
  members       ClanMember[]      @relation("member")
  pages         ClanPage[]
  ingredients   ClanIngredient[]
  discussion    ClanMessage[]
}

model ClanJoinRequest {
  id       Int      @id @default(autoincrement())
  clanId   Int
  date     DateTime @default(now()) @db.Timestamp(6)
  playerId String   @unique @db.Uuid
  clan     Clan     @relation(fields: [clanId], references: [id])
  player   Player   @relation("clanRequest", fields: [playerId], references: [id], onDelete: Cascade)
}

model ClanWar {
  id        Int       @id @default(autoincrement())
  dateStart DateTime  @default(now()) @db.Timestamp(6)
  dateEnd   DateTime?
  clans     Clan[]
}

model ClanIngredient {
  id           Int  @id @default(autoincrement())
  ingredientId Int
  quantity     Int
  clanId       Int
  clan         Clan @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([ingredientId, clanId])
  @@map("clan_ingredient")
}

model ClanMessage {
  id         Int      @id @default(autoincrement())
  clanId     Int
  date       DateTime @default(now()) @db.Timestamp(6)
  content    String
  authorId   String?  @db.Uuid
  authorName String
  author     Player?  @relation(fields: [authorId], references: [id])
  clan       Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([id, clanId])
  @@index([clanId])
  @@map("clan_messages")
}

model ClanHistory {
  id            Int      @id @default(autoincrement())
  clanId        Int
  date          DateTime @default(now()) @db.Timestamp(6)
  type          String   @default("CLAN_CREATED")
  authorId      String?  @db.Uuid
  authorMessage String
  author        Player?  @relation(fields: [authorId], references: [id])
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model ClanMember {
  id       Int      @id @default(autoincrement())
  clanId   Int
  dateJoin DateTime @default(now()) @db.Timestamp(6)
  nickname String?
  rights   String[] @default([])
  donation Int      @default(0)
  playerId String   @unique @db.Uuid
  clan     Clan     @relation("member", fields: [clanId], references: [id])
  player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([clanId])
}

model ClanPage {
  id      Int     @id @default(autoincrement())
  home    Boolean
  public  Boolean
  name    String
  content String  @default("")
  clanId  Int
  Clan    Clan    @relation(fields: [clanId], references: [id])

  @@index([clanId])
}

model Moderation {
  id         Int               @id @default(autoincrement())
  dinozId    Int?
  reason     ModerationReason
  comment    String
  banDate    DateTime?
  banEndDate DateTime?
  sorted     ModerationAction?
  reporterId String?           @db.Uuid
  targetId   String            @db.Uuid
  dinoz      Dinoz?            @relation(fields: [dinozId], references: [id])
  reporter   Player?           @relation("ReporterRelation", fields: [reporterId], references: [id])
  target     Player            @relation("TargetRelation", fields: [targetId], references: [id])
  bannedUser Player?           @relation("AcceptedBan")
}

model Conversation {
  id              String         @id @default(dbgenerated("uuid_generate_v4()"))
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  title           String
  pinnedMessageId Int?           @unique
  createdById     String?        @db.Uuid
  playerId        String?        @db.Uuid
  createdByName   String
  createdBy       Player?        @relation("CreatedConversations", fields: [createdById], references: [id])
  pinnedMessage   Message?       @relation("PinnedMessage", fields: [pinnedMessageId], references: [id])
  Player          Player?        @relation(fields: [playerId], references: [id])
  messages        Message[]      @relation("ConversationMessages")
  participants    Participants[]
}

model Participants {
  id             Int          @id @default(autoincrement())
  conversationId String
  joinedAt       DateTime     @default(now())
  playerId       String?      @db.Uuid
  playerName     String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  player         Player?      @relation(fields: [playerId], references: [id])

  @@unique([playerId, conversationId])
}

model Message {
  id             Int           @id @default(autoincrement())
  content        String
  createdAt      DateTime      @default(now())
  conversationId String
  senderId       String?       @db.Uuid
  senderName     String
  pinnedIn       Conversation? @relation("PinnedMessage")
  conversation   Conversation  @relation("ConversationMessages", fields: [conversationId], references: [id])
  sender         Player?       @relation(fields: [senderId], references: [id])
}

model Notification {
  id       String               @id @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  message  String
  severity NotificationSeverity @default(info)
  link     String?
  read     Boolean              @default(false)
  date     DateTime             @default(now()) @db.Timestamp(6)
  playerId String               @db.Uuid
  player   Player               @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, read])
  @@index([date])
}

model FightArchive {
  id                    String          @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fighters              String          @db.Text
  steps                 String          @db.Text
  seed                  String          @db.VarChar(255)
  result                Boolean         @db.Boolean
  playerId              String?         @db.Uuid
  player                Player?         @relation("PlayerRelation", fields: [playerId], references: [id])
  leftPlayerId          String?         @db.Uuid
  leftPlayer            Player?         @relation("LeftPlayerRelation", fields: [leftPlayerId], references: [id])
  rightPlayerId         String?         @db.Uuid
  rightPlayer           Player?         @relation("RightPlayerRelation", fields: [rightPlayerId], references: [id])
  tournamentStep        Int             @default(0)
  slot                  Int             @default(0)
  createdDate           DateTime        @default(now()) @db.Timestamp(6)
  Tournament            Tournament?     @relation(fields: [tournamentId], references: [id])
  tournamentTeamLeftId  String?         @db.Uuid
  tournamentTeamLeft    TournamentTeam? @relation("LeftTeamRelation", fields: [tournamentTeamLeftId], references: [id])
  tournamentTeamRightId String?         @db.Uuid
  tournamentTeamRight   TournamentTeam? @relation("RightTeamRelation", fields: [tournamentTeamRightId], references: [id])
  tournamentId          String?         @db.Uuid
  metadata              String?         @db.Text
  FightWatched          FightWatched[]
  FBTournament          FBTournament?   @relation(fields: [FBTournamentId], references: [id])
  FBTournamentId        String?         @db.Uuid
  FBTournamentLeft      GameDinoz?      @relation("LeftTeamRelationFB", fields: [FBTournamentLeftId], references: [id])
  FBTournamentLeftId    Int?
  FBTournamentRight     GameDinoz?      @relation("RightTeamRelationFB", fields: [FBTournamentRightId], references: [id])
  FBTournamentRightId   Int?
}

model FightWatched {
  id             String       @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  fight          FightArchive @relation(fields: [fightArchiveId], references: [id])
  player         Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId       String       @db.Uuid
  favorite       Boolean
  fightArchiveId String       @db.Uuid

  @@unique([playerId, fightArchiveId])
  @@index([playerId, fightArchiveId])
}

model Tournament {
  id           String           @id @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  date         DateTime         @default(now()) @db.Timestamp(6)
  formatName   String           @default("ffa") @db.Text
  teamSize     Int              @default(1)
  raceMinimum  Int              @default(1)
  poison       Boolean          @default(true)
  teamRace     String           @db.Text
  levelLimit   Int              @default(50)
  participants TournamentTeam[]
  fights       FightArchive[]
  cashPrice    Int              @default(0)
  nextRound    DateTime         @default(now())

  @@index([id, date])
}

model TournamentTeam {
  id                String         @id() @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  dojoId            String?        @db.Uuid
  dojo              Dojo?
  dinoz             Dinoz[]
  teamCount         Int            @default(1)
  Tournament        Tournament?    @relation(fields: [tournamentId], references: [id])
  tournamentId      String?        @db.Uuid
  FightArchiveLeft  FightArchive[] @relation("LeftTeamRelation")
  FightArchiveRight FightArchive[] @relation("RightTeamRelation")

  @@unique([dojoId, tournamentId])
  @@index([dojoId])
}

model FBTournament {
  id           String         @id @unique @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  date         DateTime       @default(now()) @db.Timestamp(6)
  teamRace     String         @db.Text
  levelLimit   Int            @default(50)
  participants GameDinoz[]
  fights       FightArchive[]
  cashPrice    Int            @default(0)
  nextRound    DateTime       @default(now())
  winnerId     Int?

  @@index([id, date])
}

model GameDinoz {
  id                 Int                    @id() @default(autoincrement())
  name               String                 @db.VarChar
  raceId             Int
  level              Int
  nextUpElementId    Int
  nextUpAltElementId Int
  display            String                 @db.VarChar
  life               Int
  maxLife            Int
  experience         Int
  nbrUpFire          Int
  nbrUpWood          Int
  nbrUpWater         Int
  nbrUpLightning     Int
  nbrUpAir           Int
  canChangeName      Boolean                @default(false)
  createdDate        DateTime               @default(now()) @db.Timestamp(6)
  seed               String                 @default(dbgenerated("uuid_generate_v4()"))
  usage              GameDinozUsage
  playerId           String?                @db.Uuid
  player             Player?                @relation(fields: [playerId], references: [id], onDelete: SetNull, onUpdate: NoAction, map: "FK_064135f23ecaf0207af9926d7c9")
  items              DinozItem[]
  dinozItemsToDinoz  DinozItemToDinoz[]
  skills             DinozSkill[]
  unlockableSkills   DinozSkillUnlockable[]
  status             DinozStatus[]
  FBTournament       FBTournament?          @relation(fields: [FBTournamentId], references: [id])
  FBTournamentId     String?                @db.Uuid
  FightArchiveLeft   FightArchive[]         @relation("LeftTeamRelationFB")
  FightArchiveRight  FightArchive[]         @relation("RightTeamRelationFB")

  @@index([usage])
  @@map("gamedinoz")
}

model Events {
  event            EventType
  playerId         String    @db.Uuid
  player           Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  totalProgression Int
  dailyProgression Int

  @@id([event, playerId])
}

