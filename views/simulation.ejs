<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guerriers du Givre - Simulation</title>
    <!-- On inclut le CSS global, font-awesome, et le CSS spécifique -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/pages/simulation.css">
    <link rel="icon" type="image/png" href="/img/logo.png">
</head>

<body>
    <header class="hub-header">
        <div class="header-overlay">
            <div class="header-content">
                <div class="user-info">
                    <h1>
                        <%= pseudo %>
                    </h1>
                    <p class="status"><strong>
                            <%= role %>
                        </strong> des Guerriers du Givre depuis <%= daysMember %> jours</p>
                </div>

                <div class="nav-menu">
                    <a href="/dashboard" class="nav-btn" title="Accueil"><i class="fas fa-home"></i></a>
                    <a href="/dinozs" class="nav-btn" title="Mes Dinozs"><i class="fas fa-paw"></i></a>
                    <a href="/clan" class="nav-btn disabled" title="Mon Clan"><i class="fas fa-chess-rook"></i></a>
                    <a href="/arbres" class="nav-btn" title="Plans"><i class="fas fa-scroll"></i></a>
                    <a href="/simulation" class="nav-btn" title="Simulation"><i class="fas fa-flask"></i></a>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content">
        <!-- FILTRES ET SELECTION D'EQUIPE -->
        <section id="selection-section">
            <div class="simulation-selection-layout">
                <!-- COLONNE GAUCHE : EQUIPE A -->
                <aside class="team-sidebar team-a-sidebar">
                    <div class="team-box" id="team-a-box">
                        <h3>Équipe A (<span id="team-a-count">0</span>/6)</h3>
                        <div id="team-a-slots" class="team-slots"></div>
                        <button class="btn-clear" id="btn-clear-a">Vider A</button>
                    </div>
                </aside>

                <!-- COLONNE CENTRE : FILTRES ET LISTE -->
                <div class="selection-center">
                    <div class="filters">
                        <div class="filter-group">
                            <div class="filter-toggle-group" id="filter-type-group">
                                <button type="button" class="toggle-btn active" data-value="all">Tous</button>
                                <button type="button" class="toggle-btn" data-value="real">Dinozs</button>
                                <button type="button" class="toggle-btn" data-value="ghost">Plans</button>
                            </div>
                        </div>
                        <div class="filter-group">
                            <label>Races :</label>
                            <div class="custom-dropdown" id="race-dropdown">
                                <div class="dropdown-selected" id="race-dropdown-selected">Toutes</div>
                                <div class="dropdown-list hidden" id="race-dropdown-list">
                                    <!-- JS injects checkboxes here -->
                                </div>
                            </div>
                        </div>
                        <div class="filter-group">
                            <label>Niveau :</label>
                            <div class="dual-range-wrapper">
                                <div class="dual-range-container">
                                    <div class="slider-inner">
                                        <div class="slider-track"></div>
                                        <div class="slider-range" id="slider-range"></div>
                                        <div class="slider-tooltip" id="tip-min">1</div>
                                        <div class="slider-tooltip" id="tip-max">80</div>
                                        <input type="range" id="filter-level-min" min="1" max="80" value="1">
                                        <input type="range" id="filter-level-max" min="1" max="80" value="80">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="filter-group">
                            <label>Joueurs :</label>
                            <div class="custom-dropdown" id="player-dropdown">
                                <div class="dropdown-selected" id="player-dropdown-selected">Tous</div>
                                <div class="dropdown-list hidden" id="player-dropdown-list">
                                    <!-- JS injects checkboxes here -->
                                </div>
                            </div>
                        </div>
                        <div id="current-user-pseudo" class="hidden"><%= pseudo %></div>

                        <div class="filter-group action-group">
                            <label>&nbsp;</label>
                            <button id="btn-start-mode1" class="gg-btn start-btn" disabled title="Lancer l'analyse">
                                <i class="fas fa-flask"></i>
                            </button>
                        </div>
                    </div>

                    <div id="fighter-list-container" class="fighter-list-grid"></div>
                </div>

                <!-- COLONNE DROITE : EQUIPE B -->
                <aside class="team-sidebar team-b-sidebar">
                    <div class="team-box" id="team-b-box">
                        <h3>Équipe B (<span id="team-b-count">0</span>/6)</h3>
                        <div id="team-b-slots" class="team-slots"></div>
                        <button class="btn-clear" id="btn-clear-b">Vider B</button>
                    </div>
                </aside>
            </div>
        </section>

        <!-- INTERFACE D'ANALYSE MODE 1 -->
        <section id="analysis-section" class="hidden">
            <div class="analysis-top-bar">
                <button id="btn-back-selection" class="gg-btn"><i class="fas fa-arrow-left"></i> Retour</button>
                <div class="mode-toggles">
                    <label class="switch-label">
                        <input type="checkbox" id="toggle-display-range">
                        <span class="switch-text">[Min-Max]</span>
                    </label>
                </div>
            </div>

            <div class="analysis-panels">
                <div class="panel" id="panel-a">
                    <div class="panel-header">
                        <select id="select-a" class="active-dropdown"></select>
                        <button id="btn-shield-a" class="btn-aura" style="display:none;" onclick="toggleShield('A')"
                            title="Aura Hermétique (+20% armure)">
                            🛡️ Aura
                        </button>
                    </div>
                    <div class="combat-stats" id="stats-container-a"></div>
                    <div class="fighter-sheet" id="sheet-a"></div>
                </div>

                <div class="panel" id="panel-b">
                    <div class="panel-header">
                        <select id="select-b" class="active-dropdown"></select>
                        <button id="btn-shield-b" class="btn-aura" style="display:none;" onclick="toggleShield('B')"
                            title="Aura Hermétique (+20% armure)">
                            🛡️ Aura
                        </button>
                    </div>
                    <div class="combat-stats" id="stats-container-b"></div>
                    <div class="fighter-sheet" id="sheet-b"></div>
                </div>
            </div>
        </section>
    </main>

    <!-- INJECTION DES DONNEES RESTANTES -->
    <script id="dinoz-data" type="application/json"><%- JSON.stringify(allDinozs) %></script>
    <script id="plan-data" type="application/json"><%- JSON.stringify(allPlans) %></script>
    <script id="skills-data" type="application/json"><%- JSON.stringify(allSkills) %></script>
    <script id="races-data" type="application/json"><%- JSON.stringify(allRaces) %></script>

    <script>
        const CURRENT_USER_PSEUDO = "<%= pseudo %>";
    </script>
    <script src="/js/pages/simulation.js"></script>
</body>

</html>