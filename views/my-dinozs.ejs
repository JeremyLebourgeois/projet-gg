<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mes Dinozs - Guerriers du Givre</title>
    <link rel="icon" type="image/png" href="/img/logo.png">

    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/pages/my-dinozs.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>

<body class="hub-body">

    <header class="hub-header">
        <div class="header-overlay">
            <div class="header-content">
                <div class="user-info">
                    <h1>
                        <%= pseudo %>
                    </h1>
                    <p class="status"><strong>
                            <%= role %>
                        </strong> des Guerriers du Givre depuis <%= daysMember %> jours</p>
                </div>

                <div class="nav-menu">
                    <a href="/dashboard" class="nav-btn" title="Accueil"><i class="fas fa-home"></i></a>
                    <a href="/dinozs" class="nav-btn" title="Mes Dinozs"><i class="fas fa-paw"></i></a>
                    <a href="/clan" class="nav-btn disabled" title="Mon Clan"><i class="fas fa-chess-rook"></i></a>
                    <a href="/arbres" class="nav-btn" title="Plans"><i class="fas fa-scroll"></i></a>
                    <a href="/simulation" class="nav-btn" title="Simulation"><i class="fas fa-flask"></i></a>
                </div>
            </div>
        </div>
    </header>

    <main class="dino-container">

        <div class="toolbar">
            <div class="search-group">
                <input type="text" placeholder="Rechercher un dinoz ..." class="search-input">
            </div>

            <button class="btn-tool btn-race">Races</button>
            <button class="btn-tool btn-congealed"><i class="fas fa-snowflake"></i></button>
            
            <div class="role-filter-group" style="position: relative; display: inline-block;">
                <button class="btn-tool btn-roles" id="btn-roles" type="button">Rôles <i class="fas fa-chevron-down"></i></button>
                <div class="roles-dropdown hidden" id="roles-dropdown" style="position: absolute; top: 100%; left: 0; z-index: 100; background: #2b2e38; border: 1px solid #444; border-radius: 8px; padding: 10px; margin-top: 5px; min-width: 160px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="ALL" checked> Tous
                    </label>
                    <div style="border-bottom: 1px solid #444; margin: 5px 0;"></div>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="PVP"> PVP
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="PVE"> PVE
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="Récolteur"> Récolteur
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="Compétence U"> Compétence U
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="Défis Dojo"> Défis Dojo
                    </label>
                    <label style="display: flex; align-items: center; gap: 10px; padding: 5px 0; color: #ddd; cursor: pointer;">
                        <input type="checkbox" class="role-checkbox" value="Test"> Test
                    </label>
                </div>
            </div>

            <div class="spacer"></div>
            <button class="btn-tool btn-new">Nouveau Dinoz</button>

        </div>

        <div class="dino-grid" id="user-dino-grid">
            <% dinozs.forEach(dino=> { %>
                <a href="/dinoz/<%= dino.id %>" class="dino-card <%= dino.note ? 'card-with-note' : '' %>"
                    data-congealed="<%= dino.isCongealed %>" data-role="<%= dino.role || '' %>" <% if (dino.note) { %> data-note="<%= dino.note %>" <% } %>>

                            <div class="card-img-container" style="position: relative;">
                                <img src="<%= dino.imageUrl ? dino.imageUrl : '/img/races/' + dino.race.toLowerCase() + '.png' %>"
                                    alt="<%= dino.race %>">
                                <% if (dino.isCongealed===1) { %>
                                    <div
                                        style="position: absolute; top: 0px; right: 0px; color: #4fc3f7; text-shadow: 0 0 5px black; font-size: 1.5em;">
                                        <i class="fas fa-snowflake"></i>
                                    </div>
                                    <% } %>
                            </div>
                            <div class="card-info">
                                <h3>
                                    <%= dino.name %>
                                </h3>
                                <p>
                                    <%= dino.race %> Niv.<%= dino.level %>
                                </p>
                            </div>
                </a>
                <% }) %>

                    <% if (dinozs.length===0) { %>
                        <div class="empty-state">Aucun Dinoz trouvé.</div>
                        <% } %>

                            <div class="empty-state search-empty" style="display: none;">
                                Aucun résultat pour cette recherche.
                            </div>
        </div>

        <div class="dino-grid hidden" id="race-selector-grid"></div>

        <div id="new-dino-modal" class="modal-overlay hidden">
            <div class="modal-box">
                <h2>Nouveau Dinoz</h2>
                <form action="/dinozs/create" method="POST">

                    <div class="form-group">
                        <label>Nom du Dinoz</label>
                        <input type="text" name="name" required maxlength="25">
                    </div>

                    <div class="form-group">
                        <label>Race du Dinoz</label>
                        <select name="race" id="race-select" required>
                            <option value="Castivore">Castivore</option>
                            <option value="Gorilloz">Gorilloz</option>
                            <option value="Hippoclamp">Hippoclamp</option>
                            <option value="Moueffe">Moueffe</option>
                            <option value="Nuagoz">Nuagoz</option>
                            <option value="Pigmou">Pigmou</option>
                            <option value="Planaille">Planaille</option>
                            <option value="Pteroz">Pteroz</option>
                            <option value="Rocky">Rocky</option>
                            <option value="Sirain">Sirain</option>
                            <option value="Wanwan">Wanwan</option>
                            <option value="Winks">Winks</option>
                            <option value="Feross">Feross</option>
                            <option value="Kabuki">Kabuki</option>
                            <option value="Mahamuti">Mahamuti</option>
                            <option value="Quetzu">Quetzu</option>
                            <option value="Santaz">Santaz</option>
                            <option value="Smog">Smog</option>
                            <option value="Soufflet">Soufflet</option>
                            <option value="Toufufu">Toufufu</option>
                            <option value="Triceragnon">Triceragnon</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Rôle du Dinoz</label>
                        <select name="role" id="role-select" required>
                            <option value="PVP">PVP</option>
                            <option value="PVE">PVE</option>
                            <option value="Récolteur">Récolteur</option>
                            <option value="Compétence U">Compétence U</option>
                            <option value="Défis Dojo">Défis Dojo</option>
                            <option value="Test">Test</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Apparence</label>
                        <div class="radio-group">
                            <label>
                                <input type="radio" name="skinType" value="custom" checked
                                    onchange="toggleUrlInput(true)">
                                URL dinoz
                            </label>
                            <label>
                                <input type="radio" name="skinType" value="default" onchange="toggleUrlInput(false)">
                                Apparence Glaciale
                            </label>
                        </div>
                        <input type="url" name="imageUrl" id="url-input" placeholder="https://..." required
                            style="margin-top: 10px;">
                    </div>

                    <div class="form-group">
                        <label>Note</label>
                        <input type="text" name="note" placeholder="Ex: opti TID 40">
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn-cancel" id="close-modal">Annuler</button>
                        <button type="submit" class="btn-submit">Elever</button>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <script src="/js/pages/my-dinozs.js"></script>
</body>

</html>